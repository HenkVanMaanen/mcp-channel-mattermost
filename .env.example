# Required: Mattermost base URL (no trailing /api/v4) and a bot personal access token
MATTERMOST_URL=https://mattermost.example.com
MATTERMOST_TOKEN=replace-with-bot-personal-access-token

# Required if you list channels by name (not by ID): the team the bot lives in
MATTERMOST_TEAM=myteam

# Comma-separated allowlist. Each entry is a username (without @) or a 26-char user ID.
# DMs and @mentions from these users are forwarded to Claude.
MATTERMOST_ALLOWED_USERS=alice,bob

# Optional: forward every post in these channels (names or 26-char IDs).
# The bot must be a member of each channel to receive events.
# MATTERMOST_LISTEN_CHANNELS=ops-alerts,deploys

# Optional: where to persist the pairing-fallback allowlist.
# Default: ~/.mcp-channel-mattermost/state.json
# MATTERMOST_STATE_FILE=/var/lib/mcp-channel-mattermost/state.json
